{
  "key": "fetch-domains-list",
  "flow": "sys-tasks",
  "domain": "discovery",
  "version": "1.0.0",
  "flowVersion": "1.0.0",
  "tags": [
    "domain",
    "api",
    "http",
    "fetch",
    "pagination"
  ],
  "attributes": {
    "type": "6",
    "config": {
      "url": "{{discoveryBaseUrl}}/api/v1/discovery/workflows/domain/functions/data?Page=1&PageSize=10",
      "method": "GET",
      "headers": {
        "Content-Type": "application/json",
        "accept": "*/*"
      },
      "timeoutSeconds": 30,
      "validateSsl": false
    }
  }
}

